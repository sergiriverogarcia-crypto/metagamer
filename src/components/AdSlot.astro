---
interface Props {
  label?: string;
  compact?: boolean;
}

const { label = "Espacio reservado para anuncio", compact = false } = Astro.props;
const showPlaceholder = import.meta.env.PUBLIC_SHOW_AD_PLACEHOLDERS === "true";
---

{showPlaceholder && <aside class:list={["ad-slot", { compact }]} aria-label={label} hidden />}
