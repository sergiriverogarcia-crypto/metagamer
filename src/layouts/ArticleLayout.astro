---
import BaseLayout from "./BaseLayout.astro";
import AdSlot from "@/components/AdSlot.astro";
import CoverArt from "@/components/CoverArt.astro";
import { SITE, getCategory } from "@/data/site";
import { articleSlug, formatDate } from "@/utils/articles";

const { entry } = Astro.props;
const category = getCategory(entry.data.category);
const canonical = `/articulos/${articleSlug(entry)}/`;
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: entry.data.title,
  description: entry.data.description,
  author: {
    "@type": "Organization",
    name: entry.data.author
  },
  publisher: {
    "@type": "Organization",
    name: SITE.name
  },
  datePublished: entry.data.date.toISOString(),
  dateModified: entry.data.updated.toISOString(),
  mainEntityOfPage: new URL(canonical, SITE.url).toString()
};
---

<BaseLayout title={entry.data.title} description={entry.data.description} canonical={canonical}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <article class="article-page">
    <header class="article-hero">
      <div class="article-hero-copy">
        <a class="category-link" href={`/categoria/${entry.data.category}/`}>{category?.name}</a>
        <h1>{entry.data.title}</h1>
        <p>{entry.data.description}</p>
        <div class="article-meta">
          <span>{entry.data.author}</span>
          <span>Actualizado: {formatDate(entry.data.updated)}</span>
          <span>{entry.data.readingTime}</span>
        </div>
      </div>
      <div class="article-hero-art">
        <CoverArt variant={entry.data.cover} title={entry.data.game} />
      </div>
    </header>
    <AdSlot />
    <div class="article-body">
      <slot />
    </div>
    <AdSlot label="Espacio reservado tras la guía" compact />
  </article>
</BaseLayout>
